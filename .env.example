# GitHubBench-Delta environment overrides
# Copy to .env and fill in secrets. Never commit .env.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (Codex coding agent + healthcare RGA assess when set)
OPENAI_API_KEY=

# Optional model override for POST /healthcare/assess (default gpt-4o-mini on OpenAI)
HEALTHCARE_ASSESS_MODEL=

# MiniCPM via local Ollama (OpenAI-compatible)
# Also used as healthcare RGA LLM fallback when OPENAI_API_KEY is unset.
MINICPM_BASE_URL=http://localhost:11434/v1
MINICPM_API_KEY=ollama
MINICPM_MODEL=minicpm

# GitHub (optional for live repo tasks)
GITHUB_TOKEN=

# Config paths (optional)
GITHUBBENCH_CONFIG_DIR=configs
GITHUBBENCH_SEED=42

# Frontend integration (CORS + default experiment for facade APIs)
# Include Vite/Lovable ports (5173 and 8080). Localhost any-port also allowed via regex in app.py.
GITHUBBENCH_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
GITHUBBENCH_DEFAULT_EXPERIMENT=exp_6afa2ce533ba4e0a

# Live per-patient case runs (POST /cases/run)
# Default agent is local MiniCPM; set codex when OPENAI_API_KEY + quota are available.
GITHUBBENCH_CASE_AGENT=minicpm
GITHUBBENCH_CASE_DATASET=datasets/v1
# true = gold-answer dry-run (CI/offline); false = real agent call
GITHUBBENCH_CASE_DRY_RUN=false

# Gemini — synthetic patient generation only (not judge / not agent under test)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
